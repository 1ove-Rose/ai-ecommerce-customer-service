# LLM Provider - DeepSeek/OpenAI compatible
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
MODEL_NAME=deepseek-chat
OPENAI_TEMPERATURE=0

# PostgreSQL local database
DATABASE_URL=postgresql+asyncpg://postgres:123456@127.0.0.1:5432/smartcs

# Redis local cache
REDIS_URL=redis://localhost:6379/0

# Local RAG
KNOWLEDGE_BASE_DIR=./knowledge_base
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./vector_store/faiss_index
EMBEDDING_BACKEND=sentence_transformers
LOCAL_EMBEDDING_MODEL=./models/bge-small-zh-v1.5
HF_ENDPOINT=https://hf-mirror.com
HASH_EMBEDDING_DIM=1536

# OpenTelemetry optional
OTEL_SERVICE_NAME=smart-cs-multi-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER=always_on

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false